-- Functions

function placeTemp()
	local ray = Ray.new(mouse.UnitRay.Origin, (mouse.Hit.p - mouse.UnitRay.Origin).unit * 5000)
	hitPart = workspace:FindPartOnRayWithWhitelist(ray,map.Tiles:GetChildren())
	--print(hitPart)
	if hitPart then
		if hitPart:FindFirstChild("Taken") and hitPart.Taken.Value == false then
			temp.Parent = spawnedTemps
			local Height = (0.5 * temp.HumanoidRootPart.Size.Y) + temp.Humanoid.HipHeight
			temp.HumanoidRootPart.CFrame = (hitPart.CFrame * CFrame.Angles(0,math.rad(-90),0)) + Vector3.new(0,Height + 1.75,0) 
			temp.HumanoidRootPart.Anchored = true
		end
	end
end

function clearOldTemp()
	unselected()
	if connection then
		connection:Disconnect()
	end
	for i, v in pairs(spawnedTemps:GetChildren()) do
		if v.Name == player.Name then
			v.Parent = nil
		end
	end
end

