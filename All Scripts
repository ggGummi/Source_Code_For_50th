function Fighter.spawn(player,fighterName,tile)
	
	tile.Taken.Value = true
	local newFighter = {}
	setmetatable(newFighter,Fighter)
	
	-- fighterName = Polnareff123456789
	-- baseFightername = Polnareff
	
	local fighterDisplayName = string.gsub(fighterName, "%d+", "")
	
	local templateClone = figherTemplates[fighterDisplayName]:Clone()
	templateClone.Parent = spawnedFighters
	
	newFighter.Character = templateClone
	newFighter.Character.Name = fighterName
	
	newFighter.DisplayName = fighterDisplayName
	newFighter.CodeName = fighterName
	--print(newFighter.DisplayName)
	--print(newFighter.CodeName)
	
	newFighter.Owner = player.Name
	newFighter.Level = fighterDatabase[fighterDisplayName].Level
	newFighter.Type = fighterDatabase[fighterDisplayName].Type
	newFighter.StarRating = fighterDatabase[fighterDisplayName].StarRating
	newFighter.Cost = fighterDatabase[fighterDisplayName].Cost
	newFighter.Health = fighterDatabase[fighterDisplayName].Health
	newFighter.Range = fighterDatabase[fighterDisplayName].Range
	newFighter.Damage = fighterDatabase[fighterDisplayName].Damage -- * newFighter.Level
	newFighter.AttackSpeed = fighterDatabase[fighterDisplayName].AttackSpeed
	newFighter.Lane = tonumber(tile.Parent.Name)
	newFighter.Tile = tonumber(tile.Name)
	
	local Height = (0.5 * newFighter.Character.HumanoidRootPart.Size.Y) + newFighter.Character.Humanoid.HipHeight
	newFighter.Character.HumanoidRootPart.CFrame = (tile.CFrame * CFrame.Angles(0,math.rad(-90),0)) + Vector3.new(0,Height + 1.75,0)
	newFighter.Character.HumanoidRootPart.Anchored = true
	
	local idleTrack = newFighter.Character.Humanoid:LoadAnimation(idleAnimation)
	idleTrack:Play()
	
	newFighter.Character.Humanoid.Died:Connect(function()
		warn("fighter sold?")
	end)
	
	return newFighter
end

function Fighter:Attack(dmg)
	-- Code to show atk
	
	-- Damage enemy
	if self.Type == "Attack" then
		if true then
			local ray = workspace:Raycast(self.Character.HumanoidRootPart.Position, self.Character.HumanoidRootPart.CFrame.LookVector * Vector3.new(1000,1000,1000),FighterParam)
			if ray and ray.Instance and not ray.Instance.Parent:IsA("Accessory") then -- and ray.Instance.CollisionGroupId == 1 then
				local enemy = ray.Instance.Parent
				if enemy ~= nil then
					if enemy:FindFirstChild("Humanoid") and (self.Character.HumanoidRootPart.Position - enemy.HumanoidRootPart.Position).Magnitude <= 3.5 + self.Range then -- have to check twice cuz of wait above
						--print(self.Character.Name.." hit "..enemy.Name.."!")
						--print("Range: "..tostring(self.Range))
						--print("Magnitude: "..tostring((self.Character.HumanoidRootPart.Position - enemy.HumanoidRootPart.Position).Magnitude))
						--print("Damage: "..tostring(self.Damage))
						--print("-------------------------------------------------")
						local atkTrack = self.Character.Humanoid:LoadAnimation(self.Character.Anims.Attack)
						atkTrack:Play()
						wait(self.Character.Anims.AttackTime.Value)
						if enemy:FindFirstChild("Humanoid") then
							enemy.Humanoid:TakeDamage(dmg)
						end
					end
				end
			end
		elseif self.Type == "Farm" then
			if game.Players:FindFirstChild(self.Owner) then
				local player = game.Players:FindFirstChild(self.Owner)

				local atkTrack = self.Character.Humanoid:LoadAnimation(self.Character.Anims.Attack)
				atkTrack:Play()
				player.Cash.Value += self.Damage
			else
				warn("player left?")
			end
		else
			--print("sold?")
		end
	end
end

