local rs = game:GetService("ReplicatedStorage")
local pfs = game:GetService("PathfindingService")

local Enemy = {}
Enemy.__index = Enemy

local map = game.Workspace.Map
local tiles = map.Tiles

local enemiesFolder = game.ServerStorage:WaitForChild("Enemies")
local spawnedEnemies = game.Workspace:WaitForChild("SpawnedEnemies")

function Enemy.spawn(enemyName,enemyTraits)
	
	local newEnemy = {}
	setmetatable(newEnemy,Enemy)
	
	local enemyTemplate = enemiesFolder:FindFirstChild(enemyName)
	newEnemy.Damage = enemyTraits["Damage"]
	newEnemy.Lane = math.random(#game.Workspace.Map.Tiles:GetChildren())
	--print(newEnemy.Lane)
	newEnemy.Character = enemyTemplate:Clone()
	newEnemy.Character.Lane.Value = newEnemy.Lane
	newEnemy.Character.Name = newEnemy.Character.Name..tostring(math.random(1,999999))
	newEnemy.Character.Humanoid.DisplayName = newEnemy.Character.Name
	newEnemy.Character.HumanoidRootPart.CFrame = CFrame.new(map.Other[tostring(newEnemy.Lane)].Start.Position, map.Other[tostring(newEnemy.Lane)].End.Position)
	newEnemy.Character.Humanoid.WalkSpeed = enemyTraits["Speed"]
	newEnemy.Character.Humanoid.MaxHealth = enemyTraits["MaxHealth"]
	newEnemy.Character.Humanoid.Health = enemyTraits["MaxHealth"]
	newEnemy.Character.Parent = spawnedEnemies
	
	for i,v in pairs(newEnemy.Character:GetChildren()) do
		if v:IsA("BasePart") then
			v:SetNetworkOwner(nil)
		end
	end
	
	newEnemy.Character.Humanoid.Died:Connect(function()
		newEnemy.Character:Destroy()
	end)
	
	coroutine.resume(coroutine.create(function()
		newEnemy:Move()
	end))
	
	return newEnemy
end

function Enemy:Move()
	coroutine.resume(coroutine.create(function()
		local NPC = self.Character
		
		local path = pfs:CreatePath()
		
		if NPC:FindFirstChild("Humanoid") then
			while NPC:FindFirstChild("HumanoidRootPart") and (NPC.HumanoidRootPart.Position - map.Other[tostring(self.Lane)].End.Position).Magnitude > 2.5 do
				NPC.Humanoid:MoveTo(map.Other[tostring(self.Lane)].End.Position)
				--print("moving again")
				wait(2)
			end
			--NPC.Humanoid.MoveToFinished:Wait()
		end
		
		if rs.Values.BaseHealth.Value > 0 and self.Character:FindFirstChild("Humanoid") then
			rs.Values.BaseHealth.Value -=  self.Damage
		end
		
		NPC:Destroy()
	end))
end

return Enemy

